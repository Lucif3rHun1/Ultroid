# Don't use quotes ( " and ' )
#
# SECURITY: Never paste a real token in chat, screenshots, or shell
# history. Use `bash startup` -> Setup -> "Set BOT_TOKEN" for a
# silent paste that is stripped from history. If a token is ever
# exposed, immediately message @BotFather -> /revoke -> /token.

API_ID=
API_HASH=
SESSION=


# [OPTIONAL]

REDIS_URI=
REDIS_PASSWORD=
LOG_CHANNEL=
BOT_TOKEN=

# Space-separated plugin names to enable at startup.
ENABLED_PLUGINS=

# Persisted startup state used by the launcher.
STARTUP_STATE=

# Set to "json" to emit log records as one-line JSON instead of
# human-readable text. Read by pyUltroid._misc.json_log.
LOG_FORMAT=
